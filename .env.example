# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=ingest
ENV=dev
LOG_LEVEL=INFO
LOG_JSON=true

# ── Kafka / Redpanda ──────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:19092
KAFKA_CLIENT_ID=driver-analytics
KAFKA_SCHEMA_REGISTRY=http://localhost:18081
TOPIC_FRAMES_RAW=frames.raw
TOPIC_INFER_DETECTOR=infer.detector
TOPIC_INFER_FACE=infer.face
TOPIC_INFER_EYE=infer.eye
TOPIC_INFER_HAND=infer.hand
TOPIC_INFER_RESULTS=infer.results
TOPIC_EVENTS_BEHAVIOR=events.behavior
TOPIC_EVENTS_ALERT=events.alert
TOPIC_EVIDENCE_READY=events.evidence_ready
TOPIC_DLQ=dlq

# ── Redis (hot state + frame cache) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
FRAME_CACHE_TTL_SEC=2

# ── Postgres ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/driver_analytics

# ── Object storage (S3 / MinIO) ───────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET_EVIDENCE=driver-evidence
S3_BUCKET_MODELS=driver-models

# ── Triton ────────────────────────────────────────────────────────────────────
TRITON_URL=localhost:8001                # gRPC
TRITON_HTTP_URL=http://localhost:8000
TRITON_MODEL_DETECTOR=rfdetr_driver_behaviour_onnx
TRITON_MODEL_DETECTOR_VERSION=
TRITON_MODEL_EYE=eye_state
TRITON_MODEL_HAND=hand_detector

# ── Inference / pipeline ──────────────────────────────────────────────────────
DETECTOR_INPUT_SIZE=576
DETECTOR_CONF_THRESHOLD=0.35
INGEST_BASE_FPS=8
INGEST_ESCALATED_FPS=15
INGEST_MOTION_GATE=true

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=driver-analytics
PROMETHEUS_PORT=9100

# ── API ───────────────────────────────────────────────────────────────────────
API_JWT_SECRET=change-me
API_CORS_ORIGINS=*
